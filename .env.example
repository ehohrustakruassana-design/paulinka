TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=

# The family calendar that should receive new events.
GOOGLE_CALENDAR_ID=0549d8693f971d591421d2c74b77a1dccab5e4031d6dc91417e272e25267f13c@group.calendar.google.com

# Easiest option: point to the downloaded Google service account JSON file.
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=

# Recommended: share the Google Calendar with a service account email.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional bot behavior.
BOT_MODE=polling
BOT_TIMEZONE=Europe/Warsaw
BOT_LANGUAGE=ru
DEFAULT_EVENT_DURATION_MINUTES=60
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# For webhook hosting (for example Google Cloud Run).
PORT=8080
PUBLIC_BASE_URL=
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=

# If Telegram voice notes arrive as ogg/opus, the bot converts them before transcription.
# Set this to ffmpeg or to an absolute path if ffmpeg is not on PATH.
FFMPEG_PATH=ffmpeg
